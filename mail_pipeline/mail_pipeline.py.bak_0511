"""
メールパイプライン v4
- v3からの変更: マッチング前にPython側でスキルフィルタリング（上位10名に絞り込み）
- Notionエンジニア4,642名をそのままAIに渡すとトークン超過 → Python側でフィルタリング後に渡す
"""

import imaplib
import email
import re
